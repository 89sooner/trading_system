# ─────────────────────────────────────────────
# Trading System — environment variable template
# Copy to .env and fill in values as needed.
# .env is gitignored; never commit real secrets.
# ─────────────────────────────────────────────

# ── Database (Supabase) ───────────────────────
# Supabase connection string. Leave empty for local file-based storage.
# Example: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=

# ── API Security ──────────────────────────────
# Comma-separated list of valid API keys.
# Leave empty to disable API key enforcement.
TRADING_SYSTEM_ALLOWED_API_KEYS=

# Path to the file-based API key store (managed via /admin UI).
# Default: data/api_keys.json
TRADING_SYSTEM_API_KEYS_PATH=

# ── CORS ──────────────────────────────────────
# Comma-separated allowed origins. Default: * (from configs/base.yaml)
TRADING_SYSTEM_CORS_ALLOW_ORIGINS=

# ── Rate Limiting ─────────────────────────────
# Max requests per window per client+path (default: 60)
TRADING_SYSTEM_RATE_LIMIT_MAX_REQUESTS=
# Window size in seconds (default: 60)
TRADING_SYSTEM_RATE_LIMIT_WINDOW_SECONDS=

# ── Config & Storage ──────────────────────────
# Path to the main YAML config file (default: configs/base.yaml)
TRADING_SYSTEM_CONFIG_PATH=
# Directory for pattern set JSON files (default: configs/patterns)
TRADING_SYSTEM_PATTERN_DIR=
# Directory for strategy profile JSON files (default: configs/strategies)
TRADING_SYSTEM_STRATEGY_DIR=
# Directory for portfolio persistence (default: data/portfolio)
TRADING_SYSTEM_PORTFOLIO_DIR=
# Directory for file-based backtest run persistence when DATABASE_URL is unset (default: data/runs)
TRADING_SYSTEM_RUNS_DIR=
# Directory for file-based live equity snapshots when DATABASE_URL is unset (default: data/equity)
TRADING_SYSTEM_EQUITY_DIR=
# Directory for market data CSV files (default: data/market)
TRADING_SYSTEM_CSV_DIR=

# ── Live Trading ──────────────────────────────
# Single API key used for live execution mode
TRADING_SYSTEM_API_KEY=
# Set to 1 to enable live order submission (default: disabled)
TRADING_SYSTEM_ENABLE_LIVE_ORDERS=
# Number of bar samples for live warmup (default: 2)
TRADING_SYSTEM_LIVE_BAR_SAMPLES=
# Live polling interval in seconds
TRADING_SYSTEM_LIVE_POLL_INTERVAL=
# Heartbeat interval in seconds
TRADING_SYSTEM_HEARTBEAT_INTERVAL=
# Reconciliation interval in seconds
TRADING_SYSTEM_RECONCILIATION_INTERVAL=
# Optional outbound webhook for selected runtime events
TRADING_SYSTEM_WEBHOOK_URL=
# Comma-separated event names for webhook delivery
TRADING_SYSTEM_WEBHOOK_EVENTS=
# Webhook delivery timeout in seconds
TRADING_SYSTEM_WEBHOOK_TIMEOUT=

# ── KIS Integration ───────────────────────────
TRADING_SYSTEM_KIS_BASE_URL=
TRADING_SYSTEM_KIS_APP_KEY=
TRADING_SYSTEM_KIS_APP_SECRET=
TRADING_SYSTEM_KIS_CANO=
TRADING_SYSTEM_KIS_ACNT_PRDT_CD=
TRADING_SYSTEM_KIS_ENV=
TRADING_SYSTEM_KIS_MARKET_DIV=
TRADING_SYSTEM_KIS_ORDER_TR_ID=
TRADING_SYSTEM_KIS_PRICE_TR_ID=
TRADING_SYSTEM_KIS_BALANCE_TR_ID=
